{
  "name": "multiforum-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "test": "node --loader ts-node/esm --test $(find . -path './node_modules' -prune -o -path './ts_emitted' -prune -o -path './tests/integration' -prune -o -name '*test.ts' -print | sort)",
    "test:integration": "TESTCONTAINERS_REUSE_ENABLE=true node --loader ts-node/esm --test --test-concurrency=1 $(find ./tests/integration -name '*test.ts' -print 2>/dev/null | sort)",
    "coverage": "c8 node --loader ts-node/esm --test $(find . -path './node_modules' -prune -o -path './ts_emitted' -prune -o -path './tests/integration' -prune -o -name '*test.ts' -print | sort)",
    "coverage:integration": "TESTCONTAINERS_REUSE_ENABLE=true c8 node --loader ts-node/esm --test --test-concurrency=1 $(find ./tests/integration -name '*test.ts' -print 2>/dev/null | sort)",
    "test:integration:shard": "bash build_scripts/integration-shard.sh",
    "coverage:merged": "bash build_scripts/coverage-merged.sh",
    "prepare": "husky",
    "codegen": "node --loader ts-node/esm build_scripts/generateTypes.ts",
    "lint": "eslint .",
    "lint:circular": "madge --circular --extensions ts --exclude 'ogm_types.ts|src/generated' index.ts customResolvers.ts permissions.ts",
    "tsc": "tsc",
    "logSchema": "node build_scripts/logSchema.js",
    "provision": "node --loader ts-node/esm build_scripts/provisionServerDefaults.ts",
    "build": "pnpm run codegen && tsc && node build_scripts/copyCypherFiles.js",
    "heroku-postbuild": "pnpm run build",
    "start": "node ./ts_emitted/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@google-cloud/storage": "^7.7.0",
    "@graphql-tools/delegate": "12.0.18",
    "@graphql-tools/schema": "^10.0.2",
    "@neo4j/graphql": "^5.12.11",
    "@neo4j/graphql-ogm": "^5.9.1",
    "@sendgrid/mail": "^8.1.4",
    "@types/tar-stream": "^3.1.4",
    "axios": "^1.18.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "graphql-depth-limit": "^1.1.0",
    "graphql-middleware": "^6.1.35",
    "graphql-shield": "^7.6.5",
    "graphql-tag": "^2.12.7",
    "graphql-type-json": "^0.3.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "luxon": "^3.5.0",
    "markdown-it": "^14.3.0",
    "mathjs": "^15.2.0",
    "ncp": "^2.0.0",
    "neo4j-driver": "^5.28.3",
    "node-cache": "^5.1.2",
    "random-word-slugs": "^0.1.7",
    "resend": "^6.17.1",
    "tar-stream": "^3.1.7"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.1.3",
    "@graphql-codegen/typescript": "6.0.2",
    "@graphql-codegen/typescript-resolvers": "6.0.2",
    "@testcontainers/neo4j": "^12.0.4",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/luxon": "3.7.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "c8": "^11.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "madge": "^8.0.0",
    "testcontainers": "^12.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "pnpm": {
    "overrides": {
      "whatwg-url": "^11.0.0",
      "tr46": "^4.1.0",
      "lodash": "^4.18.0",
      "uuid": "^11.1.1"
    },
    "ignoredBuiltDependencies": [
      "@apollo/protobufjs",
      "cpu-features",
      "protobufjs",
      "ssh2"
    ]
  }
}
